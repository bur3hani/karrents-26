# NODE_ENV & PORT: Server runtime configuration
NODE_ENV="production"
PORT=3000

# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: The URL where this applet is hosted.
APP_URL="MY_APP_URL"

# STRIPE PAYMENTS INTEGRATION
# Configure Stripe secret and public keys to process live client payments.
# If omitted, the applet operates in instant-activation client demo mode.
STRIPE_SECRET_KEY=""
STRIPE_WEBHOOK_SECRET=""
VITE_STRIPE_PUBLIC_KEY=""

# GITHUB OAUTH: Client Credentials configured for github.com integration
GITHUB_CLIENT_ID=""
GITHUB_CLIENT_SECRET=""

